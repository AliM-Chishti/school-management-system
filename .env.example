################################################################################
# School Management System - Environment Configuration
# Copy this file to .env and update the values for your environment
################################################################################

# APPLICATION SETTINGS
APP_NAME="School Management System"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=http://localhost

# LOCALE SETTINGS
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# MAINTENANCE MODE
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ENCRYPTION
BCRYPT_ROUNDS=12

################################################################################
# LOGGING CONFIGURATION
################################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################################################################
# DATABASE CONFIGURATION
# Default: SQLite (recommended for single-server production)
# For production on Render, SQLite is optimal as it's file-based
################################################################################
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Alternative MySQL configuration (if needed)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sms_db
# DB_USERNAME=root
# DB_PASSWORD=

################################################################################
# SESSION CONFIGURATION
################################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

################################################################################
# BROADCASTING & FILESYSTEM
################################################################################
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

################################################################################
# QUEUE CONFIGURATION
# Using database queue for production - no external dependencies needed
################################################################################
QUEUE_CONNECTION=database

################################################################################
# CACHE CONFIGURATION
# Using database cache for production
################################################################################
CACHE_STORE=database
# CACHE_PREFIX=

################################################################################
# REDIS CONFIGURATION (Optional - for advanced deployments)
################################################################################
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MEMCACHED (Optional - if using Memcached)
MEMCACHED_HOST=127.0.0.1

################################################################################
# MAIL CONFIGURATION
# Default: log driver (emails logged to storage/logs/laravel.log)
# For SMTP, update these settings
################################################################################
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# SMTP Example (uncomment and configure for real email)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=465
# MAIL_USERNAME=your_username
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=tls

################################################################################
# AWS S3 CONFIGURATION (Optional - if using S3 for file storage)
################################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

################################################################################
# VITE FRONTEND BUILD CONFIGURATION
################################################################################
VITE_APP_NAME="${APP_NAME}"

################################################################################
# DEPLOYMENT-SPECIFIC SETTINGS
################################################################################
# Trusted Proxies (required when behind a load balancer like Render's)
TRUSTED_PROXIES=*

# Force HTTPS in production (enable after SSL certificate is configured)
FORCE_HTTPS=false

# API Rate Limiting (throttle requests per minute)
RATE_LIMIT=60
